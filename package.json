{
  "name": "aiqwhisper",
  "version": "2.0.0",
  "description": "AIQwhisper — On-Premises NetApp Infrastructure Manager. A standalone alternative to Active IQ Unified Manager for ONTAP, StorageGRID, and E-Series systems.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "init-db": "node -e \"require('./src/db/database.js').initialize()\"",
    "collect": "node -e \"require('./src/scheduler/poller.js').runNow()\"",
    "learn": "node -e \"require('./src/analysis/autoLearner.js').runNow()\""
  },
  "keywords": [
    "netapp",
    "ontap",
    "storagegrid",
    "e-series",
    "infrastructure",
    "monitoring",
    "storage",
    "capacity-planning",
    "performance",
    "msp"
  ],
  "author": "ebeauzec",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
