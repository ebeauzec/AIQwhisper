# ============================================================
# AIQwhisper Configuration
# ============================================================
# Copy this file to .env and modify as needed.
# All values shown are defaults.

# --- Server ---
PORT=3080
BIND_ADDRESS=127.0.0.1
LOG_LEVEL=info                         # debug, info, warn, error

# --- Database ---
DB_PATH=./data/aiqwhisper.db

# --- Security ---
MASTER_PASSPHRASE=changeme             # Used to encrypt stored credentials (CHANGE THIS!)

# --- Collection Intervals ---
POLL_INTERVAL_MINUTES=15               # Inventory & config collection
PERF_POLL_INTERVAL_MINUTES=5           # Performance metrics collection
CAPACITY_POLL_INTERVAL_MINUTES=15      # Capacity snapshots

# --- Data Retention ---
RETENTION_RAW_DAYS=7                   # Raw metrics (5-min granularity)
RETENTION_HOURLY_DAYS=30               # Hourly rollups
RETENTION_DAILY_DAYS=180               # Daily rollups (6 months)
RETENTION_WEEKLY_DAYS=365              # Weekly rollups (12 months)

# --- Auto-Learning ---
AUTO_LEARN_ENABLED=true                # Fetch EOL/release data from public sources
AUTO_LEARN_SCHEDULE=0 2 * * 0          # Cron: Sundays at 2:00 AM
EOL_API_URL=https://endoflife.date/api/v1/products

# --- SSL ---
REJECT_UNAUTHORIZED=false              # Accept self-signed certs (typical for on-prem)
